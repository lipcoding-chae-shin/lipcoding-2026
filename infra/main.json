  "parameters": {
    "environmentName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "metadata": {
        "description": "Name of the azd environment — used to derive resource names."
      }
    },
    "location": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "Primary location for all resources."
      }
    },
    "azureOpenAiEndpoint": {
      "type": "string",
      "defaultValue": ""
    },
    "azureOpenAiApiKey": {
      "type": "securestring",
      "defaultValue": ""
    },
    "azureOpenAiDeployment": {
      "type": "string",
      "defaultValue": ""
    },
    "azureOpenAiApiVersion": {
      "type": "string",
      "defaultValue": ""
